OPENAI_API_KEY="sk-..."
VAPID_PUBLIC_KEY="...base64url uncompressed P-256 point..."
VAPID_PRIVATE_KEY="...base64url 32-byte scalar..."
VAPID_SUBJECT="mailto:you@example.com"
